{
  "name": "markdown-to-telegram",
  "version": "0.1.0",
  "description": "Prepare and publish Markdown articles to Telegram through Bot API or TDLib.",
  "type": "module",
  "license": "MIT",
  "author": "El Hombre <elhombre.dev@gmail.com>",
  "keywords": [],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "md2tg": "./bin/md2tg"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./transport-bot-api": {
      "types": "./dist/transport-bot-api/index.d.ts",
      "default": "./dist/transport-bot-api/index.js"
    },
    "./transport-tdlib": {
      "types": "./dist/transport-tdlib/index.d.ts",
      "default": "./dist/transport-tdlib/index.js"
    },
    "./pdf-thumbnail": {
      "types": "./dist/pdf-thumbnail/index.d.ts",
      "default": "./dist/pdf-thumbnail/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "jsonc-parser": "^3.3.1",
    "markdown-it": "^14.1.0",
    "pdf-to-png-converter": "^3.7.1",
    "prebuilt-tdlib": "^0.1008049.0",
    "sharp": "^0.34.5",
    "tdl": "^8.0.3"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "typescript": "^5.9.3"
  }
}
